    {"template": "{relation} 별일 없으시죠", "context": "general"},
    {"template": "{relation}, {season_event} 잘 보내세요", "context": "event"},
    {"template": "잘 지내시죠?", "context": "general"},
    {"template": "{relation}, {health_concern} 어떠세요", "context": "health"},
    {"template": "{relation}, 식사 챙기세요", "context": "general"},
    {"template": "{weather_note} 조심하세요", "context": "weather"},
    {"template": "{relation}, 오늘 어떠셨어요?", "context": "general"},
    {"template": "{relation} {topic} 어땠어요?", "context": "hobby"}
  ],
  "playful": [
    {"template": "{relation}~ 살아계신가요ㅋㅋ", "context": "general"},
    {"template": "{relation}, {weather_note} 진짜 너무함요 ㅠㅠ", "context": "weather"},
    {"template": "{relation}, {season_event}인데 뭐 드시고 계심?", "context": "event"},
    {"template": "{relation} {topic} 사진 좀 보내봐요", "context": "hobby"},
    {"template": "{relation}, 저 보고 싶죠? ㅎㅎ", "context": "general"},
    {"template": "{relation}, {health_concern} 조심하셔야 해요 진짜로", "context": "health"},
    {"template": "{relation}~ {weather_note}니까 이불 밖은 위험해요", "context": "weather"},
    {"template": "{relation}, {season_event} 끝나면 우리 뭐 먹으러 가요", "context": "event"},
    {"template": "{relation}~ 오늘도 평화로우신가요", "context": "general"},
